{
  "name": "@kurokeita/conductor-for-all",
  "author": "Minh Le",
  "repository": {
    "type": "git",
    "url": "https://github.com/kurokeita/conductor-for-all"
  },
  "license": "GPL-3.0",
  "version": "1.0.0",
  "description": "Universal Conductor prompts for AI coding agents",
  "type": "module",
  "bin": {
    "conductor-install": "./dist/install.js"
  },
  "scripts": {
    "dev": "tsx bin/install.ts",
    "build": "tsup",
    "prepublishOnly": "tsup",
    "install-prompts": "node dist/install.js",
    "uninstall-prompts": "node dist/install.js --uninstall"
  },
  "files": [
    "dist/",
    "commands/"
  ],
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@10.28.0",
  "keywords": [
    "conductor",
    "gemini",
    "copilot",
    "windsurf",
    "ai",
    "prompts"
  ],
  "dependencies": {
    "@clack/prompts": "^1.0.1",
    "commander": "^14.0.3",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
